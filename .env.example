# ══════════════════════════════════════════════════════════════════
# SkillMatch AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-secret-key
FLASK_ENV=production

# ── Database (Supabase PostgreSQL) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Supabase connection string (Session mode, port 5432):
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── AI Model ──────────────────────────────────────────────────────
# Sentence-Transformer model for semantic matching (default: all-MiniLM-L6-v2)
# Alternatives: paraphrase-MiniLM-L6-v2, all-mpnet-base-v2
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ── Rate Limiting ─────────────────────────────────────────────────
# Optional: Redis URL for distributed rate limiting across workers
# Leave empty to use in-memory (single-worker) limiting
# REDIS_URL=redis://localhost:6379/0

# ── Upload settings ───────────────────────────────────────────────
# Max upload size in MB (default: 10)
# MAX_UPLOAD_MB=10
